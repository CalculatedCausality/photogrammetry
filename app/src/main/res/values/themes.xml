<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Full-screen, no action bar, portrait-locked, screen always on.
        The activity_main layout places the GLSurfaceView edge-to-edge.
    -->
    <style name="Theme.Photogrammetry" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
